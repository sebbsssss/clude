{
  "name": "clude-bot",
  "version": "2.7.8",
  "description": "Persistent memory SDK for AI agents — Stanford Generative Agents architecture on Supabase + pgvector",
  "main": "apps/server/dist/sdk/index.js",
  "types": "apps/server/dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "require": "./apps/server/dist/sdk/index.js",
      "types": "./apps/server/dist/sdk/index.d.ts"
    },
    "./schema": "./packages/database/supabase-schema.sql",
    "./local": {
      "require": "./apps/server/dist/mcp/local-store.js",
      "types": "./apps/server/dist/mcp/local-store.d.ts"
    },
    "./mcp": {
      "require": "./apps/server/dist/mcp/server.js",
      "types": "./apps/server/dist/mcp/server.d.ts"
    }
  },
  "bin": {
    "clude-bot": "apps/server/dist/cli/index.js"
  },
  "files": [
    "apps/server/dist",
    "packages/database/supabase-schema.sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:server": "turbo dev --filter=@clude/server",
    "dev:chat": "turbo dev --filter=@clude/chat",
    "dev:dashboard": "turbo dev --filter=@clude/dashboard",
    "build": "turbo build",
    "build:sdk": "pnpm --filter @clude/server build:sdk",
    "start": "pnpm --filter @clude/server start",
    "typecheck": "turbo typecheck",
    "prepublishOnly": "pnpm --filter @clude/server build:sdk",
    "mcp": "pnpm --filter @clude/server mcp",
    "test": "turbo test",
    "test:watch": "pnpm --filter @clude/server test:watch",
    "clean": "rimraf node_modules apps/chat/node_modules apps/dashboard/node_modules apps/server/node_modules apps/server/dist packages/database/node_modules packages/tsconfig/node_modules .turbo apps/chat/.turbo apps/dashboard/.turbo apps/server/.turbo",
    "clean:install": "pnpm clean && pnpm install"
  },
  "keywords": [
    "ai-agent",
    "memory",
    "cognitive-architecture",
    "generative-agents",
    "solana",
    "supabase",
    "pgvector",
    "anthropic",
    "claude",
    "embeddings",
    "dream-cycle",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebbsssss/cludebot.git"
  },
  "homepage": "https://clude.io",
  "bugs": {
    "url": "https://github.com/sebbsssss/cludebot/issues"
  },
  "author": "sebbsssss",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "turbo": "^2.8.21"
  }
}
