{
  "name": "clude",
  "version": "0.1.0",
  "description": "Persistent memory for AI agents. Local-first, zero config.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "clude": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch",
    "test": "npx tsx test/basic.ts && npx tsx test/stress.ts"
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "llm",
    "rag",
    "local",
    "sqlite",
    "embeddings"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "ts-node": "^10.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
