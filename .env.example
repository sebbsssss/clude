# X (Twitter) API
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BOT_USER_ID=

# Anthropic (direct Claude API — fallback for inference)
ANTHROPIC_API_KEY=

# OpenRouter (primary inference — all models via single key)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Chat settings (optional)
CHAT_LLM_TIMEOUT_SEC=120
CHAT_MAX_CONTEXT_TOKENS=80000

# Web search (optional — enables web-augmented mentions)
TAVILY_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BOT_WALLET_PRIVATE_KEY=
CLUUDE_TOKEN_MINT=

# Server
PORT=3000
BASE_URL=https://your-app.railway.app

# Tuning
MENTION_POLL_INTERVAL_MS=30000
PRICE_POLL_INTERVAL_MS=60000
MOOD_TWEET_INTERVAL_MS=7200000

# Embedding system (optional — falls back to keyword scoring when disabled)
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024

# Agent API
AGENT_RATE_LIMIT=10

# Feature flags
SHOW_TX_LINKS_IN_TWEETS=false
FREE_PROMO_ENABLED=false
FREE_PROMO_CREDIT_USDC=5
FREE_PROMO_EXPIRY=
